# NVIDIA API Key — get yours at https://build.nvidia.com
# Sign up for the NVIDIA Developer Program and create an API key.
NVIDIA_API_KEY=nvapi-...

# Optional: custom API base URL (default: https://integrate.api.nvidia.com/v1)
# NV_TEST_NVIDIA_API_BASE="https://integrate.api.nvidia.com/v1"

# Test scope: all, llm, multimodal, image, audio, specialized, sample
# NV_TEST_TEST_SCOPE=all

# Max concurrent API requests
# NV_TEST_CONCURRENCY=5

# Per-request timeout in seconds
# NV_TEST_REQUEST_TIMEOUT=120

# Output directory for reports
# NV_TEST_OUTPUT_DIR=./output
